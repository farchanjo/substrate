root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Trailing spaces are significant in Markdown (line breaks).
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.toml]
indent_size = 4

[Cargo.toml]
indent_size = 4

[deny.toml]
indent_size = 2

[*.rs]
indent_size = 4

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2

[*.json]
indent_size = 2

[*.cue]
indent_size = 4

[*.rego]
indent_size = 4

[*.feature]
indent_size = 2
